# Ambiquality frontend environment.
# Copy to `.env` and adjust for your setup: `cp .env.example .env`
# All client-exposed vars MUST be prefixed with VITE_ (Vite only inlines those).
# In dev, the three API base URLs route through Caddy on :8080 (see ambiquality-backend/dev.sh).
# In prod, point them at the real HTTPS origins; treat backend URIs as permanent.

# Auth.Api base — register / login / refresh / account management.
# Dev default (via Caddy): http://localhost:8080/auth
VITE_AUTH_API_BASE=http://localhost:8080/auth

# Evidence.Api base — operator catalog (buildings/rooms/sensors), temporal edits, asOf reads.
# Dev default (via Caddy): http://localhost:8080/evidence
VITE_EVIDENCE_API_BASE=http://localhost:8080/evidence

# Public.Api base — open-data read API consumed by the visitor interface (/v1/*).
# Dev default (via Caddy): http://localhost:8080/public
VITE_PUBLIC_API_BASE=http://localhost:8080/public

# Map tile/style URL — a MapLibre GL style JSON from a configurable provider (EXT requirement).
# Dev default: a free demo style. Replace with your own provider/key in real deployments.
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Attribution string shown on the map (respect your tile provider's terms).
# Dev default: MapLibre demo tiles attribution.
VITE_MAP_ATTRIBUTION=© MapLibre
