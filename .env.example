# Ambiquality frontend environment.
# Copy to `.env` and adjust for your setup: `cp .env.example .env`
# All client-exposed vars MUST be prefixed with VITE_ (Vite only inlines those).
# In dev, the three API base URLs route through Caddy on :8080 (see ambiquality-backend/dev.sh).
# In prod, point them at the real HTTPS origins; treat backend URIs as permanent.

# Auth.Api base — register / login / refresh / account management.
# Dev default (via Caddy): http://localhost:8080/auth
VITE_AUTH_API_BASE=http://localhost:8080/auth

# Evidence.Api base — operator catalog (buildings/rooms/sensors), temporal edits, asOf reads.
# Dev default (via Caddy): http://localhost:8080/evidence
VITE_EVIDENCE_API_BASE=http://localhost:8080/evidence

# Public.Api base — open-data read API consumed by the visitor interface (/v1/*).
# Dev default (via Caddy): http://localhost:8080/public
VITE_PUBLIC_API_BASE=http://localhost:8080/public

# Map API mocks. When `1`, an MSW worker serves the map's read endpoints (/v1/map/snapshot,
# /v1/observations/aggregate, /v1/properties) with synthetic data so the public map runs without
# a backend. Defaults on in dev when unset; set to 0 once the real Public.Api routes exist.
VITE_ENABLE_API_MOCKS=1

# Map tile/style URL — a MapLibre GL style JSON from a configurable provider (EXT requirement).
# Default: OpenFreeMap `positron` — a free, no-API-key, no-rate-limit vector basemap with full
# street-level detail (https://openfreemap.org). Its muted palette keeps the colored IEQ markers
# legible. OpenFreeMap is self-hostable, so prod can point this at your own deployment.
# Other ready styles: .../styles/liberty (full color), .../styles/bright, .../styles/dark.
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron

# Attribution string shown on the map (HTML; respect the provider's terms). OpenFreeMap asks for
# OpenFreeMap + OpenMapTiles + OpenStreetMap credit.
VITE_MAP_ATTRIBUTION=<a href="https://openfreemap.org" target="_blank" rel="noopener">OpenFreeMap</a> <a href="https://www.openmaptiles.org/" target="_blank" rel="noopener">© OpenMapTiles</a> Data from <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a>
