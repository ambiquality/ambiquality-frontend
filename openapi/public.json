      "get": {
        "tags": [
          "Observations"
        ],
        "summary": "Export observations as CSV",
        "description": "Streams the filtered observation set as a downloadable CSV archive (CC BY 4.0).",
        "operationId": "ExportObservationsCsv",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "head": {
        "tags": [
          "Observations"
        ],
        "summary": "Export observations as CSV",
