{
  "openapi": "3.1.1",
  "info": {
    "title": "Ambiquality Public API",
    "description": "Read-only open-data API for the Ambiquality IEQ (Indoor Environmental Quality) monitoring platform: time-series observations (JSON, JSON-LD, CSV), the building/room/sensor evidence catalog, and a DCAT-AP 3.0 dataset description. All responses are published under CC BY 4.0.",
    "contact": {
      "name": "Vilém Charwot, VŠE Prague"
    },
    "license": {
      "name": "CC BY 4.0",
      "url": "https://creativecommons.org/licenses/by/4.0/",
      "identifier": "CC-BY-4.0"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:8080/"
    }
  ],
